# Pin approved image tags here before real deployment.
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.108.0
PROMETHEUS_IMAGE=prom/prometheus
LOKI_IMAGE=grafana/loki
TEMPO_IMAGE=grafana/tempo:2.9.1
GRAFANA_IMAGE=grafana/grafana

PROMETHEUS_RETENTION=15d

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

LOKI_PUSH_ENDPOINT=http://loki:3100/loki/api/v1/push
TEMPO_OTLP_ENDPOINT=tempo:4317
TEMPO_OTLP_INSECURE=true
CENTRAL_DEFAULT_BATCH_TIMEOUT=5s
CENTRAL_LOG_BATCH_TIMEOUT=250ms
