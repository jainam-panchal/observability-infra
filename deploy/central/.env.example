# Pin approved image tags here before real deployment.
# Collector image used by the central routing collector.
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.108.0

# Prometheus image that stores metrics scraped from the central collector.
PROMETHEUS_IMAGE=prom/prometheus

# Loki image that stores logs forwarded by the central collector.
LOKI_IMAGE=grafana/loki

# Tempo image that stores traces forwarded by the central collector.
TEMPO_IMAGE=grafana/tempo:2.9.1

# Grafana image used for dashboards and Explore.
GRAFANA_IMAGE=grafana/grafana

# Prometheus retention period for metrics.
# Example: 15d for a local or pilot stack.
PROMETHEUS_RETENTION=15d

# Grafana admin username for local login.
GRAFANA_ADMIN_USER=admin

# Grafana admin password for local login.
# Example: change-me for local only; use a secret in real environments.
GRAFANA_ADMIN_PASSWORD=change-me

# Loki write endpoint used by the central collector.
LOKI_PUSH_ENDPOINT=http://loki:3100/loki/api/v1/push

# Tempo OTLP gRPC endpoint used by the central collector.
TEMPO_OTLP_ENDPOINT=tempo:4317

# Whether the central collector should skip TLS verification when exporting to Tempo.
TEMPO_OTLP_INSECURE=true

# Default batch timeout for traces and metrics handled by the central collector.
CENTRAL_DEFAULT_BATCH_TIMEOUT=5s

# Faster batch timeout for logs handled by the central collector.
CENTRAL_LOG_BATCH_TIMEOUT=250ms
