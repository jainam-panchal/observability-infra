# OpenTelemetry Collector image used for the host-local collector container.
# Example: pin a tested collector build used across the project.
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.108.0

# OTLP endpoint on the central collector that receives telemetry forwarded by the host-local collector.
# Example: host.docker.internal:4317 for single-host local e2e.
CENTRAL_OTLP_ENDPOINT=host.docker.internal:4317

# Whether the local collector should skip TLS verification when forwarding to the central collector.
# Example: true for private local or internal traffic.
CENTRAL_OTLP_INSECURE=true

# Default environment attached to telemetry produced on this host.
# Example: development for local e2e.
DEPLOYMENT_ENVIRONMENT=development

# Host label stamped into resource metadata as host.name.
# Example: local-dev-host for single-host testing.
HOST_NAME=local-dev-host

# Stable host identifier stamped into resource metadata as host.id.
# Example: local-dev-host or an EC2 instance ID.
HOST_ID=local-dev-host

# Batch timeout for traces and metrics in the local collector.
# Example: 5s for stable forwarding.
LOCAL_DEFAULT_BATCH_TIMEOUT=5s

# Faster batch timeout for logs in the local collector.
# Example: 250ms for almost instant log appearance in Grafana.
LOCAL_LOG_BATCH_TIMEOUT=250ms

# File poll interval used by the local collector to read Docker logs and app file logs.
# Example: 200ms for responsive local debugging.
LOCAL_LOG_POLL_INTERVAL=200ms
