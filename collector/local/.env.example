# OTLP endpoint on the central collector that receives forwarded telemetry from this host-local collector.
# Example: central collector service DNS in prod or host.docker.internal:4317 for single-host local e2e.
CENTRAL_OTLP_ENDPOINT=central-otel-collector.internal:4317

# Whether the local collector should skip TLS verification when forwarding OTLP to the central collector.
# Example: true for private internal Docker or VPC traffic.
CENTRAL_OTLP_INSECURE=true

# Default environment attached to telemetry originating from this host.
# Example: production, staging, development.
DEPLOYMENT_ENVIRONMENT=production

# Hostname to stamp onto logs, metrics, and traces as host.name.
# Example: EC2 private hostname or a stable local-dev host label.
HOST_NAME=ip-10-0-0-10

# Stable infrastructure host identifier stamped as host.id.
# Example: EC2 instance ID.
HOST_ID=i-0123456789abcdef0

# Default batch timeout for traces and metrics before forwarding to the central collector.
# Example: 5s balances throughput and latency.
LOCAL_DEFAULT_BATCH_TIMEOUT=5s

# Faster batch timeout for logs so they appear in Loki quickly.
# Example: 250ms for near-real-time local debugging.
LOCAL_LOG_BATCH_TIMEOUT=250ms

# File log poll interval for Docker logs and app file logs.
# Example: 200ms for responsive local development.
LOCAL_LOG_POLL_INTERVAL=200ms
