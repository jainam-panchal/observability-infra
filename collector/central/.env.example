# Loki write endpoint used by the central collector log exporter.
# Example: internal Loki service URL inside the central Docker network.
LOKI_PUSH_ENDPOINT=http://loki:3100/loki/api/v1/push

# Tempo OTLP gRPC endpoint used by the central collector trace exporter.
# Example: internal Tempo gRPC endpoint inside the central Docker network.
TEMPO_OTLP_ENDPOINT=tempo:4317

# Whether the central collector should skip TLS verification when exporting traces to Tempo.
# Example: true for private internal Docker or VPC traffic.
TEMPO_OTLP_INSECURE=true

# Default batch timeout for traces and metrics handled by the central collector.
# Example: 5s for stable batching without too much delay.
CENTRAL_DEFAULT_BATCH_TIMEOUT=5s

# Faster batch timeout for logs handled by the central collector.
# Example: 250ms keeps Loki updates responsive.
CENTRAL_LOG_BATCH_TIMEOUT=250ms
