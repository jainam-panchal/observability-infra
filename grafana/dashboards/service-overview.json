              {
                "id": "links",
                "value": [
                  {
                    "title": "Open Service Performance",
                    "url": "/d/service-performance/service-performance?var-environment=${__data.fields.Environment}&var-service=${__value.raw}"
                  },
                  {
                    "title": "Open Logs",
                    "url": "/d/logs-and-errors/logs-and-errors?var-environment=${__data.fields.Environment}&var-service=${__value.raw}"
