        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "label_join(label_join((sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{deployment_environment_name=~\"$environment\"}[$__rate_interval]))), \"scope\", \"\", \"deployment_environment_name\"), \"scope\", \" / \", \"scope\", \"exported_job\")",
          "instant": true,
          "range": false,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "label_join(label_join((100 * (((sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{deployment_environment_name=~\"$environment\",http_response_status_code=~\"4..\"}[$__rate_interval]))) or on (deployment_environment_name, exported_job) (0 * (sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{deployment_environment_name=~\"$environment\"}[$__rate_interval]))))) / clamp_min((sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{deployment_environment_name=~\"$environment\"}[$__rate_interval]))), 1))), \"scope\", \"\", \"deployment_environment_name\"), \"scope\", \" / \", \"scope\", \"exported_job\")",
          "instant": true,
          "range": false,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "label_join(label_join((100 * (((sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{deployment_environment_name=~\"$environment\",http_response_status_code=~\"5..\"}[$__rate_interval]))) or on (deployment_environment_name, exported_job) (0 * (sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{deployment_environment_name=~\"$environment\"}[$__rate_interval]))))) / clamp_min((sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{deployment_environment_name=~\"$environment\"}[$__rate_interval]))), 1))), \"scope\", \"\", \"deployment_environment_name\"), \"scope\", \" / \", \"scope\", \"exported_job\")",
          "instant": true,
          "range": false,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "label_join(label_join((histogram_quantile(0.95, sum by (le, deployment_environment_name, exported_job) (rate(http_server_request_duration_seconds_bucket{deployment_environment_name=~\"$environment\"}[$__rate_interval])))), \"scope\", \"\", \"deployment_environment_name\"), \"scope\", \" / \", \"scope\", \"exported_job\")",
          "instant": true,
          "range": false,
          "refId": "D"
        },
        {
          "editorMode": "code",
          "expr": "label_join(label_join((histogram_quantile(0.99, sum by (le, deployment_environment_name, exported_job) (rate(http_server_request_duration_seconds_bucket{deployment_environment_name=~\"$environment\"}[$__rate_interval])))), \"scope\", \"\", \"deployment_environment_name\"), \"scope\", \" / \", \"scope\", \"exported_job\")",
          "instant": true,
          "range": false,
          "refId": "E"
        },
        {
          "editorMode": "code",
          "expr": "label_join(label_join((sum by (deployment_environment_name, exported_job) (http_server_active_requests{deployment_environment_name=~\"$environment\"})), \"scope\", \"\", \"deployment_environment_name\"), \"scope\", \" / \", \"scope\", \"exported_job\")",
          "instant": true,
          "range": false,
          "refId": "F"
        }
