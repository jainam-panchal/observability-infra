          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "100 * (((sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total{http_response_status_code=~\"5..\"}[5m]))) or on (deployment_environment_name, exported_job) (0 * (sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total[5m]))))) / clamp_min((sum by (deployment_environment_name, exported_job) (rate(http_server_request_count_total[5m]))), 1))",
          "instant": true,
          "range": false,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, deployment_environment_name, exported_job) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "instant": true,
          "range": false,
          "refId": "C"
