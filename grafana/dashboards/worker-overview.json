            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open Background Processing",
                    "url": "/d/background-processing/background-processing?var-environment=${__data.fields.Environment}&var-service=${__value.raw}"
                  },
                  {
                    "title": "Open Logs",
                    "url": "/d/logs-and-errors/logs-and-errors?var-environment=${__data.fields.Environment}&var-service=${__value.raw}"
