          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(15, round(sum by (job_name) (clamp_min(increase(db_query_count_total{deployment_environment_name=~\"$environment\",exported_job=~\"$service\",job_name!=\"\"}[$__range]), 0))))",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "renameByName": {
              "job_name": "Job Name",
              "Value": "DB Queries",
              "Value #A": "DB Queries"
            }
          }
        }
      ],
