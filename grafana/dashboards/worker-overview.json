      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (deployment_environment_name, exported_job) (max_over_time(worker_job_started_total{deployment_environment_name=~\"$environment\",exported_job=~\"$service\"}[$__range]))",
          "instant": true,
          "range": false,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "100 * (((sum by (deployment_environment_name, exported_job) (max_over_time(worker_job_completed_total{deployment_environment_name=~\"$environment\",exported_job=~\"$service\",job_status=~\"error|failed\"}[$__range]))) or on (deployment_environment_name, exported_job) (0 * (sum by (deployment_environment_name, exported_job) (max_over_time(worker_job_started_total{deployment_environment_name=~\"$environment\",exported_job=~\"$service\"}[$__range]))))) / clamp_min((sum by (deployment_environment_name, exported_job) (max_over_time(worker_job_started_total{deployment_environment_name=~\"$environment\",exported_job=~\"$service\"}[$__range]))), 1))",
          "instant": true,
          "range": false,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, deployment_environment_name, exported_job) (max_over_time(worker_job_duration_seconds_bucket{deployment_environment_name=~\"$environment\",exported_job=~\"$service\"}[$__range])))",
          "instant": true,
          "range": false,
          "refId": "C"
        }
      ],
      "title": "Worker Summary",
